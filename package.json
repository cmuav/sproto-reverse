{
  "name": "@cmuav/sproto-protocol",
  "version": "0.1.1",
  "description": "TypeScript implementation of the Sproto serial protocol used by Tribunus ESCs and other Sproto-based motor controllers.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist", "README.md", "LICENSE"],
  "scripts": {
    "build": "tsc",
    "test": "bun run src/test.ts",
    "test:probe": "bun run test/raw-probe.ts",
    "test:device": "bun run test/device-test.ts",
    "prepublishOnly": "tsc"
  },
  "keywords": [
    "sproto",
    "tribunus",
    "esc",
    "serial",
    "protocol",
    "motor-controller",
    "drone",
    "uav",
    "ardupilot"
  ],
  "author": "cmuav",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/cmuav/sproto-reverse.git"
  },
  "homepage": "https://github.com/cmuav/sproto-reverse#readme",
  "bugs": {
    "url": "https://github.com/cmuav/sproto-reverse/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "typescript": "^5.8.3"
  }
}
